                    <p class="text-[11px] text-slate-500 leading-relaxed">• Functional QA · Performance · Smoke Checks</p>
                </div>
            </div>
            <!-- Stage 2 -->
            <div class="m-stage">
                <div class="m-dot active"><div class="m-dot-inner"></div></div>
                <div class="m-card">
                    <h3 class="text-xs font-bold text-slate-800 mb-2">CLOUD SERVICES</h3>
                    <p class="text-[11px] text-slate-500 leading-relaxed">• Multi-Cloud · DB Migration · IAM Governance</p>
                </div>
            </div>
            <!-- Stage 3 -->
            <div class="m-stage">
                <div class="m-dot active"><div class="m-dot-inner"></div></div>
                <div class="m-card">
                    <h3 class="text-xs font-bold text-slate-800 mb-2">DEVOPS ENGINE</h3>
                    <p class="text-[11px] text-slate-500 leading-relaxed">• Kubernetes · GitOps CI/CD · Telemetry Metrics</p>
                </div>
            </div>
            <!-- Stage 4 -->
            <div class="m-stage">
                <div class="m-dot active"><div class="m-dot-inner"></div></div>
                <div class="m-card">
                    <h3 class="text-xs font-bold text-slate-800 mb-2">AI AUTOMATION</h3>
                    <p class="text-[11px] text-slate-500 leading-relaxed">• Autonomous QA · OWASP Scans · AI Reporting</p>
                </div>
            </div>
            <!-- Stage 5 Success -->
            <div class="m-stage">
                <div class="m-dot emerald"><div class="m-dot-inner"></div></div>
                <div class="m-card">
                    <h3 class="text-xs font-bold text-slate-800 mb-2">PRODUCTION ACTIVE</h3>
                    <p class="text-[11px] text-slate-500 leading-relaxed">• Prompt Bug Finder (v2.6) · Blog Craft AI (v1.2)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================================================= -->
    <!-- INTERACTIVE LINE AND PORT CALCULATION SCRIPT            -->
    <!-- ======================================================= -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('pipeline-container');

            // Draw straight connecting paths
            function drawLines() {
                if (window.innerWidth <= 860) return; // Disabled on mobile scroll list
                if (!container) return;

                const path1to2 = document.getElementById('path-1-2');
                const path2to3 = document.getElementById('path-2-3');
                const path3to4 = document.getElementById('path-3-4');
                const path4to5 = document.getElementById('path-4-5');
                const path5Top = document.getElementById('path-5-top');
                const path5Bottom = document.getElementById('path-5-bottom');

                function getPort(elId, port) {
                    const el = document.getElementById(elId);
                    if (!el) return { x: 0, y: 0 };

                    const cRect = container.getBoundingClientRect();
                    const eRect = el.getBoundingClientRect();
                    const x = eRect.left - cRect.left;
                    const y = eRect.top - cRect.top;

                    if (port === 'left') return { x: x, y: y + eRect.height / 2 };
                    if (port === 'right') return { x: x + eRect.width, y: y + eRect.height / 2 };
                    if (port === 'top') return { x: x + eRect.width / 2, y: y };
                    if (port === 'bottom') return { x: x + eRect.width / 2, y: y + eRect.height };
                }

                // Port calculations & SVG path updates
                const p1Right = getPort('node-stage1', 'right');
                const p2Left = getPort('node-stage2', 'left');
                const midX1 = (p1Right.x + p2Left.x) / 2;
                path1to2.setAttribute('d', `M ${p1Right.x} ${p1Right.y} C ${midX1} ${p1Right.y}, ${midX1} ${p2Left.y}, ${p2Left.x} ${p2Left.y}`);

                const p2Right = getPort('node-stage2', 'right');
                const p3Left = getPort('node-stage3', 'left');
                const midX2 = (p2Right.x + p3Left.x) / 2;
                path2to3.setAttribute('d', `M ${p2Right.x} ${p2Right.y} C ${midX2} ${p2Right.y}, ${midX2} ${p3Left.y}, ${p3Left.x} ${p3Left.y}`);

                const p3Right = getPort('node-stage3', 'right');
                const p4Left = getPort('node-stage4', 'left');
                const midX3 = (p3Right.x + p4Left.x) / 2;
                path3to4.setAttribute('d', `M ${p3Right.x} ${p3Right.y} C ${midX3} ${p3Right.y}, ${midX3} ${p4Left.y}, ${p4Left.x} ${p4Left.y}`);

                const p4Right = getPort('node-stage4', 'right');
                const p5Left = getPort('node-stage5', 'left');
                const midX4 = (p4Right.x + p5Left.x) / 2;
                path4to5.setAttribute('d', `M ${p4Right.x} ${p4Right.y} C ${midX4} ${p4Right.y}, ${midX4} ${p5Left.y}, ${p5Left.x} ${p5Left.y}`);

                // Stage 1 Dynamic Line Math (Top-Right, Bottom-Right, Bottom)
                const tRight1 = document.getElementById('path-1-top-right');
                const bRight1 = document.getElementById('path-1-bottom-right');
                const bPath1 = document.getElementById('path-1-bottom');
                if (tRight1 && bRight1 && bPath1) {
                    const el = document.getElementById('node-stage1');
                    const cRect = container.getBoundingClientRect();
                    const eRect = el.getBoundingClientRect();
                    const left = eRect.left - cRect.left;
                    const right = left + eRect.width;
                    const top = eRect.top - cRect.top;
                    const bottom = top + eRect.height;
                    const centerX = left + eRect.width / 2;

                    tRight1.setAttribute('d', `M ${right} ${top} Q ${right + 45} ${top} ${right + 78} ${top - 52}`);
                    bRight1.setAttribute('d', `M ${right} ${bottom} Q ${right + 45} ${bottom} ${right + 78} ${bottom + 52}`);
                    bPath1.setAttribute('d', `M ${centerX} ${bottom} L ${centerX} ${bottom + 52}`);
                }

                // Stage 2 & 3 Dynamic Line Math (Symmetric Tripod)
                for (let i = 2; i <= 3; i++) {
                    const tLeft = document.getElementById(`path-${i}-top-left`);
                    const tRight = document.getElementById(`path-${i}-top-right`);
                    const bPath = document.getElementById(`path-${i}-bottom`);
                    if (tLeft && tRight && bPath) {
                        const el = document.getElementById(`node-stage${i}`);
                        const cRect = container.getBoundingClientRect();
                        const eRect = el.getBoundingClientRect();
                        const left = eRect.left - cRect.left;
                        const right = left + eRect.width;
                        const top = eRect.top - cRect.top;
                        const bottom = top + eRect.height;
                        const centerX = left + eRect.width / 2;

                        tLeft.setAttribute('d', `M ${left} ${top} Q ${left - 45} ${top} ${left - 78} ${top - 52}`);
                        tRight.setAttribute('d', `M ${right} ${top} Q ${right + 45} ${top} ${right + 78} ${top - 52}`);
                        bPath.setAttribute('d', `M ${centerX} ${bottom} L ${centerX} ${bottom + 52}`);
                    }
                }

                // Stage 4 Dynamic Line Math (Top-Left, Top-Right, Bottom-Left)
                const tLeft4 = document.getElementById('path-4-top-left');
                const tRight4 = document.getElementById('path-4-top-right');
                const bLeft4 = document.getElementById('path-4-bottom-left');
                if (tLeft4 && tRight4 && bLeft4) {
                    const el = document.getElementById('node-stage4');
                    const cRect = container.getBoundingClientRect();
                    const eRect = el.getBoundingClientRect();
                    const left = eRect.left - cRect.left;
                    const right = left + eRect.width;
                    const top = eRect.top - cRect.top;
                    const bottom = top + eRect.height;

                    tLeft4.setAttribute('d', `M ${left} ${top} Q ${left - 45} ${top} ${left - 78} ${top - 52}`);
                    tRight4.setAttribute('d', `M ${right} ${top} Q ${right + 45} ${top} ${right + 78} ${top - 52}`);
                    bLeft4.setAttribute('d', `M ${left} ${bottom} Q ${left - 45} ${bottom} ${left - 78} ${bottom + 52}`);
                }

                // Stage 5 vertical branching lines (Offset y dynamically matches bottom-[130%] / top-[130%])
                if (path5Top && path5Bottom) {
                    const p5Top = getPort('node-stage5', 'top');
                    const p5Bottom = getPort('node-stage5', 'bottom');

                    // 173px * 0.30 = 52px branching gap offset
                    path5Top.setAttribute('d', `M ${p5Top.x} ${p5Top.y} L ${p5Top.x} ${p5Top.y - 52}`);
                    path5Bottom.setAttribute('d', `M ${p5Bottom.x} ${p5Bottom.y} L ${p5Bottom.x} ${p5Bottom.y + 52}`);
                }
            }

            // Draw initial paths and hook events
            window.addEventListener('load', drawLines);
            window.addEventListener('resize', drawLines);
            setTimeout(drawLines, 100);

            // Hover event handlers to highlight connections
            document.querySelectorAll('.flow-node').forEach(node => {
                const paths = node.getAttribute('data-paths').split(',');

                node.addEventListener('mouseenter', () => {
                    paths.forEach(pId => {
                        const path = document.getElementById(pId);
                        if (!path) return;

                        if (pId === 'path-4-5') {
                            path.classList.add('active-success');
                            path.setAttribute('marker-end', 'url(#arrow-emerald)');
                        } else {
                            path.classList.add('active');
                            path.setAttribute('marker-end', 'url(#arrow-active)');
                        }
                    });

                    // Toggle branching lines for this node stage
                    const stageNum = node.id.replace('node-stage', '');
                    const tlPath = document.getElementById(`path-${stageNum}-top-left`);
                    const trPath = document.getElementById(`path-${stageNum}-top-right`);
                    const blPath = document.getElementById(`path-${stageNum}-bottom-left`);
                    const brPath = document.getElementById(`path-${stageNum}-bottom-right`);
                    const bPath = document.getElementById(`path-${stageNum}-bottom`);
                    const tPath5 = document.getElementById(`path-${stageNum}-top`); // For stage 5

                    if (tlPath) {
                        tlPath.classList.remove('opacity-0');
                        tlPath.classList.add('opacity-100');
                    }
                    if (trPath) {
                        trPath.classList.remove('opacity-0');
                        trPath.classList.add('opacity-100');
                    }
                    if (blPath) {
                        blPath.classList.remove('opacity-0');
                        blPath.classList.add('opacity-100');
                    }
                    if (brPath) {
                        brPath.classList.remove('opacity-0');
                        brPath.classList.add('opacity-100');
                    }
                    if (bPath) {
                        bPath.classList.remove('opacity-0');
                        bPath.classList.add('opacity-100');
                    }
                    if (tPath5) {
                        tPath5.classList.remove('opacity-0');
                        tPath5.classList.add('opacity-100');
                        tPath5.setAttribute('marker-end', 'url(#arrow-emerald)');
                    }
                });

                node.addEventListener('mouseleave', () => {
                    paths.forEach(pId => {
                        const path = document.getElementById(pId);
                        if (!path) return;

                        path.classList.remove('active', 'active-success');
                        path.setAttribute('marker-end', 'url(#arrow)');
                    });

                    // Toggle branching lines for this node stage
                    const stageNum = node.id.replace('node-stage', '');
                    const tlPath = document.getElementById(`path-${stageNum}-top-left`);
                    const trPath = document.getElementById(`path-${stageNum}-top-right`);
                    const blPath = document.getElementById(`path-${stageNum}-bottom-left`);
                    const brPath = document.getElementById(`path-${stageNum}-bottom-right`);
                    const bPath = document.getElementById(`path-${stageNum}-bottom`);
                    const tPath5 = document.getElementById(`path-${stageNum}-top`); // For stage 5

                    if (tlPath) {
                        tlPath.classList.add('opacity-0');
                        tlPath.classList.remove('opacity-100');
                    }
                    if (trPath) {
                        trPath.classList.add('opacity-0');
                        trPath.classList.remove('opacity-100');
                    }
                    if (blPath) {
                        blPath.classList.add('opacity-0');
                        blPath.classList.remove('opacity-100');
                    }
                    if (brPath) {
                        brPath.classList.add('opacity-0');
                        brPath.classList.remove('opacity-100');
                    }
                    if (bPath) {
                        bPath.classList.add('opacity-0');
                        bPath.classList.remove('opacity-100');
                    }
                    if (tPath5) {
                        tPath5.classList.add('opacity-0');
                        tPath5.classList.remove('opacity-100');
                        tPath5.setAttribute('marker-end', 'url(#arrow-emerald)');
                    }
                });
            });
        });
    </script>
</body>

</html>
