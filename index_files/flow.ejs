
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CROSSTECCH Complete Enterprise Architecture Pipeline</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg: #f8fafc;
            --surface: #ffffff;
            --cyan: #0ea5e9;
            --emerald: #10b981;
            --text: #334155;
            --muted: #64748b;
            --border-dormant: #cbd5e1;
            --font-heading: 'Plus Jakarta Sans', sans-serif;
            --font-body: 'Plus Jakarta Sans', sans-serif;
        }

        /* Desktop Locked Scroll */
        @media (min-width: 861px) {
            html, body {
                height: 100vh;
                width: 100vw;
                overflow: hidden;
                margin: 0;
                padding: 0;
            }
            .desktop-view {
                display: flex !important;
            }
            .mobile-view {
                display: none !important;
            }
        }

        /* Mobile Scrolling View */
        @media (max-width: 860px) {
            body {
                overflow-y: auto;
                overflow-x: hidden;
                min-height: 100vh;
            }
            .desktop-view {
                display: none !important;
            }
            .mobile-view {
                display: block !important;
            }
        }

        body {
            background: linear-gradient(to bottom, #000000 0%, #1e293b 45%, #cbd5e1 85%, #f8fafc 100%);
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            position: relative;
        }

        /* Subtle Cyber Tech Grid matching branding theme */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(rgba(148, 163, 184, 0.15) 1px, transparent 1px);
            background-size: 24px 24px;
            pointer-events: none;
            z-index: 0;
        }

        /* Connection lines styling */
        .flow-path {
            stroke: var(--border-dormant);
            stroke-width: 2.5;
            fill: none;
            transition: stroke 0.3s ease, stroke-width 0.3s ease;
        }

        .flow-path.active {
            stroke: var(--cyan);
            stroke-width: 3.5;
        }

        .flow-path.active-success {
            stroke: var(--emerald);
            stroke-width: 3.5;
        }

        /* Animated Background Floating Orbs Keyframes */
        @keyframes float-1 {
            0% { transform: translate(10vw, 10vh) scale(1); }
            50% { transform: translate(50vw, 40vh) scale(1.15); }
            100% { transform: translate(10vw, 10vh) scale(1); }
        }
        @keyframes float-2 {
            0% { transform: translate(75vw, 65vh) scale(1.2); }
            50% { transform: translate(25vw, 15vh) scale(0.9); }
            100% { transform: translate(75vw, 65vh) scale(1.2); }
        }
        @keyframes float-3 {
            0% { transform: translate(35vw, 75vh) scale(0.95); }
            50% { transform: translate(65vw, 25vh) scale(1.1); }
            100% { transform: translate(35vw, 75vh) scale(0.95); }
        }

        .animate-float-slow-1 {
            animation: float-1 25s infinite ease-in-out;
        }
        .animate-float-slow-2 {
            animation: float-2 30s infinite ease-in-out;
        }
        .animate-float-slow-3 {
            animation: float-3 22s infinite ease-in-out;
        }

        /* Mobile timeline track track */
        @media (max-width: 860px) {
            .m-pipeline {
                padding: 16px 16px 48px;
                position: relative;
            }
            .m-pipeline::before {
                content: '';
                position: absolute;
                left: 30px;
                top: 0;
                bottom: 0;
                width: 2px;
                background: linear-gradient(to bottom, var(--border-dormant) 0%, rgba(226, 232, 240, 0.3) 100%);
            }
            .m-stage {
                display: flex;
                gap: 16px;
                margin-bottom: 28px;
            }
            .m-dot {
                flex-shrink: 0;
                width: 22px;
                height: 22px;
                border-radius: 50%;
                background: #ffffff;
                border: 2px solid var(--border-dormant);
                margin-top: 10px;
                position: relative;
                z-index: 1;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .m-dot-inner {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--border-dormant);
            }
            .m-dot.active {
                border-color: var(--cyan);
            }
            .m-dot.active .m-dot-inner {
                background: var(--cyan);
            }
            .m-dot.emerald {
                border-color: var(--emerald);
            }
            .m-dot.emerald .m-dot-inner {
                background: var(--emerald);
            }
            .m-card {
                flex: 1;
                background: #ffffff;
                border: 1px solid var(--border-dormant);
                border-radius: 18px;
                padding: 18px 20px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body, h1, h2, h3, h4, h5, h6, p, a, span, li, ul, ol, button, input, textarea, select, label, strong, em, blockquote, small, th, td, figcaption {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
        }
    </style>
</head>

