<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Our Services – CrossTecch</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        html {
            scroll-behavior: smooth;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 24px;
            overflow-x: hidden;
            position: relative;
        }
        /* Subtle dot grid background */

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(rgba(15, 23, 42, 0.05) 1px, transparent 1px);
            background-size: 32px 32px;
            pointer-events: none;
            z-index: 0;
        }
        /* Abstract fluid gradient blobs matching the purple/pink fluid art */

        .bg-blob-1 {
            position: fixed;
            width: 750px;
            height: 750px;
            background: radial-gradient(circle, rgba(168, 85, 247, 0.2) 0%, rgba(236, 72, 153, 0.12) 50%, transparent 100%);
            top: -200px;
            right: -100px;
            filter: blur(80px);
            z-index: 0;
            pointer-events: none;
            animation: morph-blob-1 18s infinite alternate ease-in-out;
        }

        .bg-blob-2 {
            position: fixed;
            width: 850px;
            height: 850px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, rgba(168, 85, 247, 0.08) 60%, transparent 100%);
            bottom: -300px;
            left: -200px;
            filter: blur(90px);
            z-index: 0;
            pointer-events: none;
            animation: morph-blob-2 22s infinite alternate ease-in-out;
        }

        @keyframes morph-blob-1 {
            0% {
                border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%;
                transform: translate(0, 0) rotate(0deg);
            }
            100% {
                border-radius: 60% 40% 40% 60% / 60% 60% 40% 40%;
                transform: translate(-40px, 60px) rotate(180deg);
            }
        }

        @keyframes morph-blob-2 {
            0% {
                border-radius: 50% 50% 30% 70% / 50% 60% 40% 50%;
                transform: translate(0, 0) rotate(0deg);
            }
            100% {
                border-radius: 30% 70% 70% 30% / 60% 30% 70% 40%;
                transform: translate(50px, -50px) rotate(-180deg);
            }
        }

        .section {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 1340px;
            margin: 0 auto;
            text-align: center;
        }
        /* ── Header ── */

        .eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: #6366f1;
            margin-bottom: 12px;
        }

        .headline {
            font-size: clamp(28px, 4vw, 50px);
            font-weight: 900;
            color: #94a3b8;
            /* Silver / slate matching screenshot */
            letter-spacing: -1.5px;
            margin-bottom: 10px;
            line-height: 1.1;
            text-transform: uppercase;
        }

        .headline span {
            color: transparent;
            background: linear-gradient(90deg, #ec4899, #a855f7, #3b82f6);
            /* Vibrant pink-to-blue gradient */
            -webkit-background-clip: text;
            background-clip: text;
        }

        .subline {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 60px;
            font-weight: 400;
        }
        /* ══════════════════════════════════
           SERVICE CARDS — individual, stacked cards.
           Each card is its own separate block in normal page flow (not a
           pinned/overlapping deck). As you scroll, each card slides up from
           below and fades in on its own, one after another — driven
           continuously off the actual scroll position, so speed/direction
           always follows the scroll exactly (scroll back up = they reverse).
        ══════════════════════════════════ */

        .cards {
            display: flex;
            flex-direction: column;
            gap: 28px;
            width: 100%;
            max-width: 880px;
            margin: 0 auto;
        }

        .card {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            min-height: 300px;
            display: flex;
            align-items: flex-end;
            text-align: left;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.14);
            /* JS sets these two continuously off scroll position — no CSS
               transition here on purpose, the scroll itself is the easing. */
            opacity: 0;
            transform: translateY(80px);
        }

        .card-bg {
            position: absolute;
            inset: 0;
        }

        .card-bg-default { opacity: 1; }
        .card-bg-active { opacity: 0; }

        .card-sheen {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.35) 0%, transparent 55%);
            pointer-events: none;
            z-index: 2;
        }

        .card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg, rgba(15, 23, 42, 0.08) 0%, transparent 45%);
            pointer-events: none;
            z-index: 2;
        }

        /* Collapsed sidebar tab isn't needed in a stacked layout */
        .card-collapsed { display: none !important; }

        .card-expanded {
            position: relative;
            z-index: 3;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 14px;
            padding: 40px 44px;
        }

        .card-expanded-tag {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: #fff;
            background: rgba(255, 255, 255, 0.16);
            backdrop-filter: blur(8px);
            padding: 6px 14px;
            border-radius: 20px;
            width: fit-content;
        }

        .card-expanded-icon {
            width: 72px;
            height: 72px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.16);
            backdrop-filter: blur(8px);
        }

        .card-expanded-icon svg {
            width: 36px;
            height: 36px;
        }

        .card-expanded-icon img {
            width: 42px;
            height: 42px;
            object-fit: contain;
        }

        .card-expanded-title {
            font-size: clamp(24px, 3vw, 32px);
            font-weight: 900;
            color: #fff;
            line-height: 1.2;
            letter-spacing: -0.5px;
        }

        .card-expanded-desc {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.9);
            line-height: 1.7;
            max-width: 560px;
        }

        .card-expanded-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #fff;
            color: #0f172a;
            font-size: 13px;
            font-weight: 700;
            padding: 12px 22px;
            border-radius: 40px;
            width: fit-content;
            margin-top: 4px;
            transition: transform 0.25s ease;
        }

        .card-expanded-cta:hover {
            transform: translateX(3px);
        }

        .card-expanded-cta svg {
            width: 16px;
            height: 16px;
        }
        /* ── Services Footer & View All Button ── */

        .services-footer {
            margin-top: 50px;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            z-index: 5;
        }

        .btn-view-all {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(90deg, #ec4899, #a855f7, #3b82f6);
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            padding: 14px 32px;
            border-radius: 40px;
            text-decoration: none;
            box-shadow: 0 8px 25px rgba(168, 85, 247, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.25);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
        }

        .btn-view-all:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 15px 35px rgba(168, 85, 247, 0.35);
        }

        .btn-view-all:active {
            transform: translateY(-1px) scale(0.98);
        }
        /* ══ CARD THEMES — background image + accent per service ══ */

        .card-1 .card-bg-default {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.2) 0%, rgba(15, 23, 42, 0.74) 100%), url('../images/manual qa.webp') center/cover no-repeat;
        }
        .card-1 .card-expanded-cta { color: #2563eb; }

        .card-2 .card-bg-default {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.2) 0%, rgba(15, 23, 42, 0.74) 100%), url('../images/automated qa.webp') center/cover no-repeat;
        }
        .card-2 .card-expanded-cta { color: #8b5cf6; }

        .card-3 .card-bg-default {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.2) 0%, rgba(15, 23, 42, 0.74) 100%), url('../images/devops.webp') center/cover no-repeat;
        }
        .card-3 .card-expanded-cta { color: #d97706; }

        .card-4 .card-bg-default {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.2) 0%, rgba(15, 23, 42, 0.74) 100%), url('../images/uiux.webp') center/cover no-repeat;
