    <script>
        const deck = document.getElementById('deck');
        const cards = Array.from(deck.querySelectorAll('.card'));

        // ══ Individual cards, stacked normally on the page. Each one slides up
        // from below and fades in as it scrolls into view, and reverses if you
        // scroll back up — driven continuously off actual scroll position, so
        // the speed/direction always matches the scroll exactly (no fixed
        // duration timer, no pinning, no single-slot deck). ══
        var embedded = (window.self !== window.top);
        var viewportH = window.innerHeight;
        var frameTop = 0;   // this iframe's own position in the parent viewport (embedded mode)
        var cardTops = [];  // each card's fixed position within this page's own layout (embedded mode)

        function measureCardTops() {
            if (!embedded) return;
            cardTops = cards.map(function (c) { return c.getBoundingClientRect().top; });
        }
        measureCardTops();

        function reveal() {
            cards.forEach(function (card, i) {
                var top = embedded ? (frameTop + cardTops[i]) : card.getBoundingClientRect().top;
                var start = viewportH * 0.92; // starts revealing near the bottom edge of the screen
                var end = viewportH * 0.55;   // fully revealed by the time it reaches mid-upper screen
                var p = (start - top) / (start - end);
                p = Math.max(0, Math.min(1, p));
                card.style.opacity = p;
                card.style.transform = 'translateY(' + (80 * (1 - p)) + 'px)';
            });
        }
        reveal();

        // Embedded: parent page (index.html) forwards its own viewport height
        // and this iframe's position within it every rAF tick while scrolling.
        window.addEventListener('message', function (e) {
            if (!e.data) return;
            if (typeof e.data.ctParentVH === 'number') {
                viewportH = e.data.ctParentVH;
                reveal();
            }
            if (typeof e.data.ctServicesFrameTop === 'number') {
                frameTop = e.data.ctServicesFrameTop;
                reveal();
            }
        });

        // Opened standalone (not inside the iframe, e.g. for testing) -> use
        // this window's own scroll directly.
        if (!embedded) {
            var ticking = false;

            function onScroll() {
                if (ticking) return;
                ticking = true;
                requestAnimationFrame(function () {
                    ticking = false;
                    reveal();
                });
            }
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        }

        window.addEventListener('resize', function () {
            viewportH = window.innerHeight;
            measureCardTops();
            reveal();
        });

        // Fonts/images can shift layout slightly after first paint — remeasure
        // a few times so card positions stay accurate.
        window.addEventListener('load', function () {
            [200, 600, 1200].forEach(function (d) {
                setTimeout(function () { measureCardTops(); reveal(); }, d);
            });
        });

        // "Explore Service" -> services.html (poora page, iframe nahi)
        function goServices(e) {
            if (e) e.stopPropagation();
            try { window.top.location.href = '/services'; }
            catch (err) { window.location.href = '/services'; }
        }
        document.querySelectorAll('.card-expanded-cta').forEach(function (cta) {
            cta.style.cursor = 'pointer';
            cta.addEventListener('click', goServices);
        });
    </script>
    <!-- ===== EMBED MODE (sirf index1.html ke andar; standalone par koi asar nahi) ===== -->
    <script>
        (function() {
            if (window.self === window.top) return;
            var s = document.createElement('style');
            s.textContent = 'body{min-height:0!important;display:block!important}';
            document.head.appendChild(s);

            function report() {
                var h = (function() {
                    var b = document.body,
                        max = 0,
                        cs;
                    for (var i = 0; i < b.children.length; i++) {
                        cs = getComputedStyle(b.children[i]);
                        if (cs.position === 'fixed' || cs.position === 'absolute' || cs.display === 'none') continue;
                        var bot = b.children[i].offsetTop + b.children[i].offsetHeight + (parseFloat(cs.marginBottom) || 0);
                        if (bot > max) max = bot;
                    }
                    return (max + (parseFloat(getComputedStyle(b).paddingBottom) || 0)) || b.scrollHeight;
                })();
                if (h > 0) parent.postMessage({
                    ctSection: true,
                    height: h
                }, '*');
            }
            window.__ctReport = report;
            window.addEventListener('load', function() {
                report();
                [200, 600, 1200, 2500].forEach(function(d) {
                    setTimeout(report, d);
                });
            });
            window.addEventListener('resize', report);
            if (window.ResizeObserver) {
                try {
                    new ResizeObserver(report).observe(document.body);
                } catch (e) {}
            }
        })();
    </script></body>

</html>
