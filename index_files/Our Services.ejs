        .card-4 .card-expanded-cta { color: #059669; }

        .card-5 .card-bg-default {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.2) 0%, rgba(15, 23, 42, 0.74) 100%), url('../images/cloud.webp') center/cover no-repeat;
        }
        .card-5 .card-expanded-cta { color: #0891b2; }
        /* ── Responsive ── */

        @media (max-width: 900px) {
            .card { min-height: 260px; }
            .card-expanded { padding: 28px 26px; }
            .card-expanded-icon { width: 56px; height: 56px; border-radius: 14px; }
            .card-expanded-icon img { width: 34px; height: 34px; }
            .card-expanded-icon svg { width: 26px; height: 26px; }
            .card-expanded-title { font-size: 21px; }
            .card-expanded-desc { font-size: 13px; line-height: 1.55; }
        }
        /* ===== Mobile: hide the heavy blurred animated blobs ===== */

        @media (max-width: 860px) {
            .bg-blob-1,
            .bg-blob-2 {
                display: none !important;
            }
        }
    </style>
