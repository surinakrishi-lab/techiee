<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | Cross Tecch</title>
    <!-- Google Fonts (Plus Jakarta Sans & Space Grotesk) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Lucide Icons CDN (Used for page cards, header uses pure inline SVGs) -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* Reset & Base Variables */

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

         :root {
            --primary-font: 'Plus Jakarta Sans', sans-serif;
            --bg-dark: #f8fafc;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --border-color: rgba(15, 23, 42, 0.06);
            --border-hover: rgba(99, 102, 241, 0.35);
            --primary: #4f46e5;
            /* Indigo 600 */
            --secondary: #2563eb;
            /* Royal Blue */
            --accent: #c026d3;
            /* Magenta 600 */
            --font-sans: 'Plus Jakarta Sans', sans-serif;
            --font-mono: 'Space Grotesk', monospace;
            --transition-smooth: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            --transition-speed: 0.3s;
            --shadow: rgba(15, 23, 42, 0.04) 0px 20px 40px -15px, rgba(15, 23, 42, 0.02) 0px 4px 6px -2px;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-dark);
            font-family: var(--primary-font);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
            background-image: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.03) 0%, transparent 40%), radial-gradient(circle at 90% 80%, rgba(37, 99, 235, 0.03) 0%, transparent 40%), linear-gradient(rgba(15, 23, 42, 0.012) 1px, transparent 1px), linear-gradient(90deg, rgba(15, 23, 42, 0.012) 1px, transparent 1px);
            background-size: 100% 100%, 100% 100%, 40px 40px, 40px 40px;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        @media (max-width: 768px) {
            .container {
                padding: 0 1.25rem;
            }
        }
        /* --- Floating Header Bar Styling (Exact copy from header/style.css) --- */

        .floating-header {
            position: fixed;
            top: 1.25rem;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 2.5rem);
            max-width: 1280px;
            height: 76px;
            background: #ffffff;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            box-shadow: 0 20px 40px -15px rgba(15, 23, 42, 0.05);
            z-index: 1000;
            display: flex;
            align-items: center;
            padding: 0 2.5rem;
        }

        .header-container {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: inherit;
        }

        .logo-icon-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-svg {
            transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .logo:hover .logo-svg {
            transform: rotate(90deg) scale(1.1);
        }

        .logo-text {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: 0.05em;
        }

        .search-bar {
            display: none;
            align-items: center;
            background: #f4f6fa;
            border-radius: 9999px;
            padding: 4px 4px 4px 1.25rem;
            width: 420px;
            border: 1px solid rgba(15, 23, 42, 0.04);
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .search-bar:focus-within {
            background: #ffffff;
            border-color: rgba(37, 99, 235, 0.4);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1), 0 10px 20px -10px rgba(15, 23, 42, 0.05);
            width: 440px;
        }

        .search-icon-left {
            flex-shrink: 0;
            margin-right: 0.5rem;
        }

        .search-input {
            border: none;
            background: transparent;
            outline: none;
            font-size: 0.85rem;
            color: #1f2937;
            width: 100%;
            font-family: inherit;
        }

        .search-input::placeholder {
            color: var(--text-muted);
        }

        .dropdown-trigger {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0 0.75rem;
            border-left: 1px solid rgba(15, 23, 42, 0.1);
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 700;
            color: #334155;
            user-select: none;
            white-space: nowrap;
        }

        .dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            right: 50px;
            margin-top: 0.5rem;
            background: #ffffff;
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
            padding: 0.5rem 0;
            z-index: 1100;
            width: 110px;
        }

        .dropdown-menu.active {
            display: block;
        }

        .dropdown-item {
            padding: 0.5rem 1rem;
            font-size: 0.8rem;
            cursor: pointer;
            color: var(--text-secondary);
            transition: background var(--transition-speed);
        }

        .dropdown-item:hover {
            background: #f1f5f9;
            color: var(--text-primary);
        }

        .search-submit-btn {
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            border: none;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            margin-left: 0.5rem;
            box-shadow: 0 4px 10px rgba(59, 130, 246, 0.25);
            flex-shrink: 0;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .search-submit-btn:hover {
            transform: scale(1.1) rotate(15deg);
            box-shadow: 0 6px 15px rgba(59, 130, 246, 0.4);
        }

        .nav-links {
            display: none;
            align-items: center;
            gap: 2rem;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.85rem;
            position: relative;
            padding: 0.25rem 0;
            transition: color var(--transition-speed);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background-color: #2563eb;
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-links a:hover {
            color: #2563eb;
        }

        .nav-links a.active {
            color: #2563eb !important;
        }

        .nav-links a:hover::after,
        .nav-links a.active::after {
            transform: scaleX(1);
            transform-origin: left;
        }

        .mobile-toggle {
            display: flex;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.25rem;
            color: var(--text-primary);
        }

        .mobile-nav-overlay {
            display: none;
            position: fixed;
            top: 96px;
            left: 1.25rem;
            right: 1.25rem;
            background: #ffffff;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            box-shadow: 0 20px 30px rgba(0, 0, 0, 0.06);
            z-index: 999;
            padding: 1.5rem;
            animation: slideDown 0.3s ease;
        }

        .mobile-nav-overlay.active {
            display: block;
        }

        .mobile-nav-content {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .mobile-search {
            display: flex;
            align-items: center;
            background: #f4f6fa;
            border-radius: 9999px;
            padding: 8px 1.25rem;
            border: 1px solid rgba(0, 0, 0, 0.02);
        }

        .mobile-search input {
            border: none;
            background: transparent;
            outline: none;
            margin-left: 0.5rem;
            width: 100%;
            font-family: inherit;
            font-size: 0.9rem;
        }

        .mobile-link {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 1.05rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.02);
            padding-bottom: 0.5rem;
            transition: color var(--transition-speed);
        }

        .mobile-link:hover {
            color: #2563eb;
        }

        .mobile-link.active {
            color: #2563eb !important;
        }
        /* --- General Section Settings --- */

        .section {
            padding: 6rem 0;
            position: relative;
        }

        .section-tag {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--primary);
            margin-bottom: 1rem;
            display: inline-block;
        }

        .section-title {
            font-size: 2.75rem;
            font-weight: 800;
            color: var(--text-primary);
            line-height: 1.15;
            letter-spacing: -0.03em;
        }

        .section-desc {
            color: var(--text-secondary);
            font-size: 1.05rem;
            line-height: 1.7;
        }

        .glass-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            box-shadow: var(--shadow);
            transition: var(--transition-smooth);
        }

        .glass-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-5px);
            box-shadow: 0 30px 50px -20px rgba(15, 23, 42, 0.08);
            background: var(--bg-card-hover);
        }
        /* --- Scroll Animation Classes --- */

        .animate-on-scroll {
            opacity: 0;
            transform: translateY(35px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            will-change: opacity, transform;
        }

        .animate-on-scroll.appear {
            opacity: 1;
            transform: translateY(0);
        }
        /* --- Hero Section --- */

        .hero-wrapper {
            margin-top: 110px;
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 4rem;
            align-items: center;
        }

        .impact-text {
            background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 50%, var(--accent) 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .arrow-icon {
            margin-top: 0.5rem;
            margin-bottom: 1.75rem;
        }

        .checklist {
            list-style: none;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 2rem;
        }

        .checklist-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-primary);
        }

        .check-icon {
            background: rgba(79, 70, 229, 0.08);
            color: var(--primary);
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        /* 3D Orbit Graphics Section */

        .orbit-container {
            position: relative;
            width: 100%;
            height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        /* Orbit Rings */

        .orbit-ring {
            position: absolute;
            border: 1px dashed rgba(15, 23, 42, 0.08);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
        }

        .orbit-ring-1 {
            width: 330px;
            height: 330px;
        }
        /* Central Pedestal Cylinders */

        .pedestal-base {
            position: absolute;
            width: 170px;
            height: 60px;
            background: #ffffff;
            border-radius: 50%;
            border: 1px solid rgba(15, 23, 42, 0.05);
            box-shadow: 0 25px 40px -10px rgba(15, 23, 42, 0.15);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) translateY(20px);
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pedestal-top {
            position: absolute;
            width: 140px;
            height: 50px;
            background: linear-gradient(180deg, #ffffff 0%, #f1f5f9 100%);
            border-radius: 50%;
            border: 1px solid rgba(15, 23, 42, 0.05);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) translateY(10px);
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-core {
            position: absolute;
            z-index: 3;
            transform: translate(-50%, -50%) translateY(-10px);
            top: 50%;
            left: 50%;
            animation: coreFloat 4s ease-in-out infinite;
        }

        @keyframes coreFloat {
            0%,
            100% {
                transform: translate(-50%, -50%) translateY(-5px);
            }
            50% {
                transform: translate(-50%, -50%) translateY(-15px);
            }
        }
        /* Orbital Nodes orbiting around the center */

        .orbital-wrapper {
            position: absolute;
            width: 330px;
            height: 330px;
            animation: spinOrbit 30s linear infinite;
        }

        @keyframes spinOrbit {
            from {
                transform: rotate(0deg);
            }
            to {
                transform: rotate(360deg);
            }
        }

        .orbit-node {
            position: absolute;
            width: 48px;
            height: 48px;
            background: #ffffff;
            border-radius: 50%;
            border: 1px solid var(--border-color);
            box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            animation: keepUpright 30s linear infinite;
            cursor: pointer;
            transition: transform 0.3s ease, border-color 0.3s ease;
        }

        .orbit-node:hover {
            transform: scale(1.15);
            border-color: var(--primary);
        }

        @keyframes keepUpright {
            from {
                transform: rotate(360deg);
            }
            to {
                transform: rotate(0deg);
            }
        }
        /* Position nodes circular coordinates around wrapper */

        .node-code {
            top: -24px;
            left: calc(50% - 24px);
            color: var(--primary);
        }

        .node-security {
            top: calc(30% - 24px);
            right: -12px;
            color: #22c55e;
        }

        .node-cloud {
            bottom: calc(20% - 24px);
            right: 24px;
            color: #f97316;
        }

        .node-chart {
            bottom: calc(20% - 24px);
            left: 24px;
            color: var(--secondary);
        }

        .node-users {
            top: calc(30% - 24px);
            left: -12px;
            color: #6366f1;
        }
        /* --- Metrics Bar --- */

        .metrics-bar {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            padding: 2.25rem;
            margin-top: 2rem;
        }

        .metric-item {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .metric-icon-box {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: rgba(79, 70, 229, 0.04);
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
        }

        .metric-num {
            font-size: 2.25rem;
            font-weight: 800;
            font-family: var(--font-mono);
            line-height: 1.1;
            color: var(--text-primary);
        }

        .metric-lbl {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 500;
        }
        /* --- Purpose Section --- */

        .purpose-header {
            text-align: center;
            margin-bottom: 4rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .purpose-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2.5rem;
        }

        .purpose-card {
            padding: 3rem;
            display: flex;
            gap: 2rem;
            align-items: flex-start;
        }

        .purpose-icon-box {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: rgba(79, 70, 229, 0.04);
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: var(--primary);
        }

        .purpose-info h3 {
            font-size: 1.4rem;
            margin-bottom: 0.75rem;
        }

        .purpose-info p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.6;
        }
        /* --- Values Section --- */

        .values-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 1.5rem;
        }

        .value-card {
            padding: 2.5rem 1.5rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .value-icon-box {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: rgba(79, 70, 229, 0.04);
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            margin-bottom: 1.5rem;
        }

        .value-card h3 {
            font-size: 1.15rem;
            margin-bottom: 0.75rem;
            font-weight: 700;
        }

        .value-card p {
            color: var(--text-secondary);
            font-size: 0.85rem;
            line-height: 1.6;
        }
        /* --- Journey Section --- */

        .timeline-container {
            position: relative;
            margin-top: 5rem;
            padding-bottom: 2rem;
        }

        .timeline-line {
            position: absolute;
            top: 24px;
            left: 0;
            right: 0;
            height: 2px;
            background: rgba(15, 23, 42, 0.08);
            z-index: 1;
        }

        .timeline-progress {
            position: absolute;
            top: 24px;
            left: 0;
            width: 0%;
            /* Animate on scroll */
            height: 2px;
            background: linear-gradient(90deg, var(--primary) 0%, var(--secondary) 100%);
            z-index: 2;
            transition: width 1.5s ease-out;
        }

        .timeline-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            position: relative;
            z-index: 3;
            gap: 2rem;
        }

        .timeline-node {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .node-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #ffffff;
            border: 2px solid rgba(15, 23, 42, 0.2);
            margin-bottom: 1.5rem;
            transition: all 0.5s ease;
            cursor: pointer;
        }

        .timeline-node.active .node-dot {
            background: var(--primary);
            border-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.2);
        }

        .node-year {
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            transition: color 0.5s ease;
        }

        .timeline-node.active .node-year {
            color: var(--primary);
        }

        .node-desc {
            font-size: 0.8rem;
            color: var(--text-secondary);
            line-height: 1.6;
            max-width: 180px;
        }
        /* --- Footer CTA Banner --- */

        .footer-cta-card {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #3b82f6 100%);
            border-radius: 24px;
            padding: 3.5rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #ffffff;
            box-shadow: 0 25px 50px -12px rgba(79, 70, 229, 0.25);
        }

        .footer-cta-info h3 {
            font-size: 2.25rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
            letter-spacing: -0.02em;
        }

        .footer-cta-info p {
            color: rgba(255, 255, 255, 0.85);
            font-size: 1.05rem;
        }

        .cta-btn {
            background: #ffffff;
            color: var(--primary);
            border: none;
            padding: 0.9rem 2rem;
            border-radius: 9999px;
            font-weight: 700;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            transition: var(--transition-smooth);
        }

        .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.12);
        }
        /* --- Footer --- */

        .footer {
            background: #090d16;
            color: #ffffff;
            padding: 6rem 0 2rem 0;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-top {
            display: grid;
            grid-template-columns: 1.2fr repeat(3, 0.8fr) 1.2fr;
            gap: 3rem;
            margin-bottom: 4rem;
        }

        .footer-brand {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .footer-brand-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: #ffffff;
        }

        .footer-brand-desc {
            color: #94a3b8;
            font-size: 0.85rem;
            line-height: 1.6;
        }

        .footer-socials {
            display: flex;
            gap: 1rem;
        }

        .social-btn {
            width: 36px;
            height: 36px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        .social-btn:hover {
            color: #ffffff;
            background: var(--primary);
            border-color: transparent;
            transform: translateY(-2px);
        }

        .footer-col h4 {
            font-family: var(--font-mono);
            font-size: 0.95rem;
            color: #ffffff;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

