    <!-- --- JAVASCRIPT --- -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize Lucide Icons (only used inside page containers)
            lucide.createIcons();

            // --- Header Navigation & Menus (Exact copy from header/script.js) ---
            const mobileToggle = document.getElementById('mobileToggle');
            const mobileNavOverlay = document.getElementById('mobileNavOverlay');
            const dropdownTrigger = document.getElementById('dropdownTrigger');
            const dropdownMenu = document.getElementById('dropdownMenu');
            const selectedCategory = document.getElementById('selectedCategory');
            const dropdownItems = document.querySelectorAll('.dropdown-item');

            // Toggle Mobile Menu Overlay
            if (mobileToggle && mobileNavOverlay) {
                mobileToggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    mobileNavOverlay.classList.toggle('active');

                    const icon = mobileToggle.querySelector('svg');
                    if (mobileNavOverlay.classList.contains('active')) {
                        icon.innerHTML = `<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>`;
                    } else {
                        icon.innerHTML = `<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>`;
                    }
                });
            }

            // Toggle Category Dropdown Menu in Search
            if (dropdownTrigger && dropdownMenu) {
                dropdownTrigger.addEventListener('click', (e) => {
                    e.stopPropagation();
                    dropdownMenu.classList.toggle('active');
                });

                // Handle Item Clicks inside Dropdown
                dropdownItems.forEach(item => {
                    item.addEventListener('click', (e) => {
                        selectedCategory.textContent = e.target.textContent;
                        dropdownMenu.classList.remove('active');
                    });
                });
            }

            // Close menus when clicking outside
            document.addEventListener('click', (e) => {
                if (dropdownMenu && !dropdownTrigger.contains(e.target) && !dropdownMenu.contains(e.target)) {
                    dropdownMenu.classList.remove('active');
                }
                if (mobileNavOverlay && !mobileToggle.contains(e.target) && !mobileNavOverlay.contains(e.target)) {
                    mobileNavOverlay.classList.remove('active');

                    const icon = mobileToggle.querySelector('svg');
                    if (icon) {
                        icon.innerHTML = `<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>`;
                    }
                }
            });

            // Handle Link Active Highlight States
            const navLinksList = document.querySelectorAll('.nav-links a, .mobile-link');
            navLinksList.forEach(link => {
                link.addEventListener('click', () => {
                    navLinksList.forEach(l => l.classList.remove('active'));
                    link.classList.add('active');
                });
            });

            // --- Intersection Observer for Scroll Animations ---
            const animateElements = document.querySelectorAll('.animate-on-scroll');

            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const scrollObserver = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('appear');

                        // If it contains the timeline container, trigger timeline line animation
                        if (entry.target.classList.contains('timeline-container')) {
                            animateTimeline();
                        }

                        // If it contains metrics box, trigger numbers count-up
                        if (entry.target.classList.contains('metrics-bar')) {
                            animateMetrics();
                        }

                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            animateElements.forEach(el => scrollObserver.observe(el));

            // --- Numerical Metrics Counter Animation ---
            function animateMetrics() {
                const counters = document.querySelectorAll('.count-target');

                counters.forEach(counter => {
                    const target = parseFloat(counter.getAttribute('data-value'));
                    const suffix = counter.getAttribute('data-suffix') || '';
                    const duration = 2000; // 2 seconds
                    let startTimestamp = null;

                    const step = (timestamp) => {
                        if (!startTimestamp) startTimestamp = timestamp;
                        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                        const currentVal = Math.floor(progress * target);

                        counter.textContent = currentVal + suffix;

                        if (progress < 1) {
                            window.requestAnimationFrame(step);
                        } else {
                            counter.textContent = target + suffix;
                        }
                    };

                    window.requestAnimationFrame(step);
                });
            }

            // --- Horizontal Timeline Progression & Node Activation ---
            function animateTimeline() {
                const progressLine = document.getElementById('timelineProgress');
                const nodes = document.querySelectorAll('.timeline-node');

                if (!progressLine) return;

                // Set line progression to 100% width
                setTimeout(() => {
                    progressLine.style.width = '100%';
                }, 300);

                // Sequentially activate timeline nodes based on their progress percentage
                nodes.forEach(node => {
                    const targetPct = parseFloat(node.getAttribute('data-percentage'));

                    // Delay node activation to sync with the progress line moving across
                    setTimeout(() => {
                        node.classList.add('active');
                    }, (targetPct / 100) * 1200 + 300);
                });
            }
        });
    </script>    <style>.floating-header{display:none!important;}</style>
