# Copy this file to .env and fill in your real MongoDB connection string.
# .env is gitignored, so real credentials never get committed.

# Get a free connection string from MongoDB Atlas:
# 1. https://www.mongodb.com/cloud/atlas/register
# 2. Create a free (M0) cluster
# 3. Database Access -> add a database user + password
# 4. Network Access -> allow your IP (or 0.0.0.0/0 for quick testing)
# 5. Connect -> "Drivers" -> copy the connection string below
# 6. Add your database name right after ".net/" (before the "?") - e.g. "/crosstecch"
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/crosstecch?retryWrites=true&w=majority

# Optional - defaults to 3000 if not set
PORT=3000
